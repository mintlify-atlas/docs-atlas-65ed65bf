  "keyFeatures": [
    "Keyboard-driven vim-like navigation with hjkl movement",
    "Rich terminal UI with multiple view modes (flat list, grouped, kanban board)",
    "Complete CLI interface for scripting and automation",
    "Sprint planning with story points and card assignments",
    "Card dependencies with parent-child and blocking relationships",
    "Undo/Redo support for all actions",
    "Real-time search and filtering capabilities",
    "MCP server for LLM integration (Claude, Cursor, etc.)",
    "Automatic JSON persistence with format migrations",
    "Multi-instance support with conflict detection"
  ],
